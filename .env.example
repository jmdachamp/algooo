# ─────────────────────────────────────────────────────────
#  Copy this file to .env and fill in your credentials.
#  NEVER commit your real .env file to version control.
# ─────────────────────────────────────────────────────────

# ── Tradovate ────────────────────────────────────────────
TRADOVATE_USERNAME=your_username
TRADOVATE_PASSWORD=your_password
TRADOVATE_APP_ID=Sample App
TRADOVATE_APP_VERSION=1.0
TRADOVATE_CID=your_cid          # from Tradovate developer portal
TRADOVATE_SECRET=your_secret    # from Tradovate developer portal

# ── Interactive Brokers (if using IBKR instead) ──────────
IBKR_HOST=127.0.0.1
IBKR_PORT=7497          # 7497=TWS paper, 7496=TWS live, 4002=GW paper, 4001=GW live
IBKR_CLIENT_ID=1

# ── Optional overrides ───────────────────────────────────
BOT_CONFIG=config.yaml  # path to your config.yaml
