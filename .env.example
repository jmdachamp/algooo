# === Broker Configuration ===
# Alpaca API credentials (paper trading by default)
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_API_SECRET=your_alpaca_api_secret_here
ALPACA_PAPER=true   # Set to false for live trading

# === Webhook Server ===
WEBHOOK_HOST=0.0.0.0
WEBHOOK_PORT=8000
WEBHOOK_SECRET=your_webhook_secret_here   # Must match TradingView alert message secret

# === Strategy Parameters ===
# EMA settings
EMA_FAST=9
EMA_MID=21
EMA_SLOW=45

# Volume
VOLUME_PERIOD=20
VOLUME_INCREASE=1.05

# Risk / Stop
STOP_LOSS_TICKS=15
RISK_REWARD=2.0
TICK_SIZE=0.01         # syminfo.mintick for your instrument (0.01 for stocks, 0.25 for ES, etc.)

# Position sizing
ACCOUNT_RISK_PERCENT=1.0   # % of account to risk per trade
MAX_POSITION_SIZE=100       # Max shares / contracts per trade

# Entry patterns
REQUIRE_ENGULFING=false
MIN_BODY_PERCENT=60.0
ALLOW_DEEP_PULLBACK=false

# EMA crossover
ENABLE_CROSSOVERS=true
ATR_MULTIPLIER=1.1
ATR_PERIOD=10
TRAIL_TICKS=10

# Exit management
ENABLE_PARTIALS=true
PARTIAL1_PERCENT=50
PARTIAL1_RR=1.0
ENABLE_BREAKEVEN=true
BREAKEVEN_RR=0.75
ENABLE_TRAILING=true
TRAIL_START_RR=1.0

# Session & time
SESSION_START=09:30
SESSION_END=15:50
FILTER_LUNCH=true
PRIME_TIME_ONLY=false
MAX_BARS_OPEN=15
TIMEZONE=America/New_York

# === Logging ===
LOG_LEVEL=INFO
LOG_FILE=logs/bot.log
